# ─────────────────────────────────────────────────────────────────────
# Uplan Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# On HuggingFace Spaces, set these in Settings > Variables and Secrets.

# ─── AMD Server (flask_app.py) ───────────────────────────────────────
# Optional API key to protect the /extract endpoint
UPLAN_API_KEY=your-secret-key-here

# ─── Gradio Frontend (app.py) ───────────────────────────────────────
# Set to "true" to call the AMD server instead of using demo data
USE_LIVE_BACKEND=true

# URL of the Flask server running on your AMD MI300X
AMD_ENDPOINT=http://your-amd-server-ip:8000/extract

# Same key as above — Gradio sends this in the X-API-Key header
# UPLAN_API_KEY=your-secret-key-here

# Optional: Anthropic API key for the consultant chat
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the Anthropic model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
